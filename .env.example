PORT=4000
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=8h
# Example: [{"username":"admin","password":"admin1234"}]
# Prefer passwordHash in production: bcrypt hash via `node -e "import bcrypt from 'bcryptjs'; bcrypt.hash('your-password', 10).then(console.log)"`
AUTH_USERS_JSON=[{"username":"admin","password":"admin1234"}]
